-- ==============================================================================
-- COMPREHENSIVE DATA CLEANING QUERY FOR subscriber_10 TABLE
-- ==============================================================================
-- This query transforms raw subscriber data by:
-- 1. Handling NULL and invalid values across all columns
-- 2. Standardising names with proper capitalization
-- 3. Normalizing gender and race values
-- 4. Validating age ranges (0-120 reasonable range)
-- 5. Standardising South African province names
-- 6. Removing duplicates based on UserID
-- 7. Converting column names to lowercase with underscores
-- ==============================================================================

WITH base_cleaning AS (
  SELECT 
    -- ==============================================================================
    -- USER ID CLEANING
    -- Ensures UserID is valid and not null
    -- ==============================================================================
    COALESCE(
      TRY_CAST(UserID AS BIGINT),
      0
    ) AS user_id,
    
    -- ==============================================================================
    -- NAME STANDARDIZATION
    -- Trims whitespace and applies proper capitalisation
    -- Handles NULL and empty values
    -- ==============================================================================
    CASE
      WHEN TRIM(COALESCE(Name, '')) = '' THEN 'Unknown'
      WHEN TRIM(COALESCE(Name, '')) = 'NULL' THEN 'Unknown'
      ELSE INITCAP(TRIM(Name))
    END AS first_name,
    
    -- ==============================================================================
    -- SURNAME STANDARDISATION
    -- Trims whitespace and applies proper capitalization
    -- Handles NULL and empty values
    -- ==============================================================================
    CASE
      WHEN TRIM(COALESCE(Surname, '')) = '' THEN 'Unknown'
      WHEN TRIM(COALESCE(Surname, '')) = 'NULL' THEN 'Unknown'
      ELSE INITCAP(TRIM(Surname))
    END AS last_name,
    
    -- ==============================================================================
    -- GENDER STANDARDISATION
    -- Normalises gender values to consistent format
    -- Handles variations like M/Male, F/Female, etc.
    -- ==============================================================================
    CASE
      WHEN UPPER(TRIM(COALESCE(Gender, ''))) IN ('M', 'MALE', 'MAN', 'BOY') THEN 'Male'
      WHEN UPPER(TRIM(COALESCE(Gender, ''))) IN ('F', 'FEMALE', 'WOMAN', 'GIRL') THEN 'Female'
      WHEN UPPER(TRIM(COALESCE(Gender, ''))) IN ('O', 'OTHER', 'NON-BINARY', 'NONBINARY') THEN 'Other'
      WHEN TRIM(COALESCE(Gender, '')) = '' THEN 'Unknown'
      ELSE 'Unknown'
    END AS gender,
    
    -- ==============================================================================
    -- RACE STANDARDISATION
    -- Normalizes South African racial categories
    -- Handles common variations and misspellings
    -- ==============================================================================
    CASE
      WHEN LOWER(TRIM(COALESCE(Race, ''))) IN ('black', 'african', 'black african') THEN 'Black African'
      WHEN LOWER(TRIM(COALESCE(Race, ''))) IN ('white', 'caucasian') THEN 'White'
      WHEN LOWER(TRIM(COALESCE(Race, ''))) IN ('coloured', 'colored', 'mixed race') THEN 'Coloured'
      WHEN LOWER(TRIM(COALESCE(Race, ''))) IN ('indian', 'asian', 'indian/asian') THEN 'Indian/Asian'
      WHEN LOWER(TRIM(COALESCE(Race, ''))) IN ('chinese') THEN 'Chinese'
      WHEN LOWER(TRIM(COALESCE(Race, ''))) IN ('other', 'mixed') THEN 'Other'
      WHEN TRIM(COALESCE(Race, '')) = '' THEN 'Unknown'
      ELSE INITCAP(TRIM(Race))
    END AS race,
    
    -- ==============================================================================
    -- AGE VALIDATION
    -- Ensures age is within reasonable range (0-120)
    -- Handles NULL and invalid values
    -- ==============================================================================
    CASE
      WHEN Age IS NULL THEN -1
      WHEN Age < 0 THEN -1
      WHEN Age > 120 THEN -1  -- Flag unrealistic ages
      ELSE Age
    END AS age,
    
    -- ==============================================================================
    -- AGE GROUP CATEGORISATION
    -- Creates age groups for demographic analysis
    -- ==============================================================================
    CASE
      WHEN Age IS NULL OR Age < 0 OR Age > 120 THEN 'Unknown'
      WHEN Age >= 0 AND Age <= 12 THEN 'Child (0-12)'
      WHEN Age >= 13 AND Age <= 17 THEN 'Teen (13-17)'
      WHEN Age >= 18 AND Age <= 24 THEN 'Young Adult (18-24)'
      WHEN Age >= 25 AND Age <= 34 THEN 'Adult (25-34)'
      WHEN Age >= 35 AND Age <= 44 THEN 'Adult (35-44)'
      WHEN Age >= 45 AND Age <= 54 THEN 'Middle Age (45-54)'
      WHEN Age >= 55 AND Age <= 64 THEN 'Senior (55-64)'
      WHEN Age >= 65 THEN 'Elderly (65+)'
      ELSE 'Unknown'
    END AS age_group,
    
    -- ==============================================================================
    -- PROVINCE STANDARDISATION
    -- Normalises South African province names
    -- Handles abbreviations and common variations
    -- ==============================================================================
    CASE
      -- Gauteng variations
      WHEN LOWER(TRIM(COALESCE(Province, ''))) IN ('gauteng', 'gp', 'gauteng province', 'gt', 'jhb', 'johannesburg', 'pretoria') THEN 'Gauteng'
      
      -- Western Cape variations
      WHEN LOWER(TRIM(COALESCE(Province, ''))) IN ('western cape', 'wc', 'w cape', 'cape town', 'cpt') THEN 'Western Cape'
      
      -- KwaZulu-Natal variations
      WHEN LOWER(TRIM(COALESCE(Province, ''))) IN ('kwazulu-natal', 'kzn', 'kwazulu natal', 'durban', 'natal') THEN 'KwaZulu-Natal'
      
      -- Eastern Cape variations
      WHEN LOWER(TRIM(COALESCE(Province, ''))) IN ('eastern cape', 'ec', 'e cape', 'east london', 'port elizabeth') THEN 'Eastern Cape'
      
      -- Limpopo variations
      WHEN LOWER(TRIM(COALESCE(Province, ''))) IN ('limpopo', 'lp', 'northern province', 'polokwane') THEN 'Limpopo'
      
      -- Mpumalanga variations
      WHEN LOWER(TRIM(COALESCE(Province, ''))) IN ('mpumalanga', 'mp', 'nelspruit', 'mbombela') THEN 'Mpumalanga'
      
      -- North West variations
      WHEN LOWER(TRIM(COALESCE(Province, ''))) IN ('north west', 'nw', 'northwest', 'north-west', 'mahikeng') THEN 'North West'
      
      -- Free State variations
      WHEN LOWER(TRIM(COALESCE(Province, ''))) IN ('free state', 'fs', 'freestate', 'bloemfontein') THEN 'Free State'
      
      -- Northern Cape variations
      WHEN LOWER(TRIM(COALESCE(Province, ''))) IN ('northern cape', 'nc', 'n cape', 'kimberley') THEN 'Northern Cape'
      
      -- Handle NULL and unknown
      WHEN TRIM(COALESCE(Province, '')) = '' THEN 'Unknown'
      
      -- Keep original if already standardized
      ELSE INITCAP(TRIM(Province))
    END AS province
    
  FROM `kenzowealth`.`default`.`subscriber_10`
),

-- ==============================================================================
-- Removes duplicate UserIDs, keeping the first occurrence
-- ==============================================================================
deduplicated AS (
  SELECT
    *,
    ROW_NUMBER() OVER (PARTITION BY user_id ORDER BY user_id) AS row_num
  FROM base_cleaning
  WHERE user_id > 0  -- Exclude invalid UserIDs
)

-- ==============================================================================
-- FINAL SELECT WITH DATA QUALITY FILTERS
-- ==============================================================================
SELECT
  user_id,
  first_name,
  last_name,
  gender,
  race,
  age,
  age_group,
  province
FROM deduplicated
WHERE 
  row_num = 1  -- Keep only first occurrence of each UserID
  AND first_name <> 'Unknown'  -- Exclude records with no name
  AND last_name <> 'Unknown'   -- Exclude records with no surname
  
-- ==============================================================================
-- SORTING
-- Orders by user_id for easier reference
-- ==============================================================================
ORDER BY user_id;


