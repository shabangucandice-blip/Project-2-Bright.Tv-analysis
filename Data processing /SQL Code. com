-- ==============================================================================
-- COMPREHENSIVE DATA CLEANING QUERY FOR viewer_11 TABLE
-- ==============================================================================
-- This query transforms raw viewer data by:
-- 1. Converting UTC timestamps to SAST (South African Standard Time)
-- 2. Separating timestamps into date and time columns
-- 3. Standardising and normalizing channel names
-- 4. Trimming whitespace from all string columns
-- 5. Handling NULL values (converting to 'Unknown')
-- 6. Handling empty/blank values
-- 7. Filtering out invalid or test channels
-- 8. Standardising column names to lowercase with underscores
-- ==============================================================================

SELECT 
  -- ==============================================================================
  -- USER ID CLEANING
  -- ==============================================================================
  COALESCE(
    TRY_CAST(TRIM(CAST(UserID AS STRING)) AS BIGINT), 
    0
  ) AS user_id,
  -- ==============================================================================
  -- CHANNEL NAME STANDARDISATION
  -- Normalizes channel names to handle:
  -- - Case variations (SABC 1, sabc1, Sabc One)
  -- - Spacing inconsistencies (e-tv, etv, e tv)
  -- - Brand grouping (Supersport variants under one brand)
  -- - NULL and empty values converted to 'Unknown'
  -- ==============================================================================
  CASE
    -- Handle NULL or empty channel names
    WHEN TRIM(COALESCE(Channel2, '')) = '' THEN 'Unknown'
    
    -- Supersport brand family consolidation
    WHEN LOWER(TRIM(Channel2)) IN (
      'supersport live events',
      'supersport live',
      'supersport events',
      'supersport',
      'supersport blitz'
    ) THEN 'Supersport'
    
    -- SABC 1 variations
    WHEN LOWER(TRIM(Channel2)) IN (
      'sabc 1',
      'sabc1',
      'sabc one'
    ) THEN 'SABC 1'
    
    -- SABC 2 variations
    WHEN LOWER(TRIM(Channel2)) IN (
      'sabc 2',
      'sabc2',
      'sabc two'
    ) THEN 'SABC 2'
    
    -- SABC 3 variations
    WHEN LOWER(TRIM(Channel2)) IN (
      'sabc 3',
      'sabc3',
      'sabc three'
    ) THEN 'SABC 3'
    
    -- eTV variations
    WHEN LOWER(TRIM(Channel2)) IN (
      'etv',
      'e-tv',
      'e tv'
    ) THEN 'eTV'
    
    -- Mzansi Magic variations
    WHEN LOWER(TRIM(Channel2)) IN (
      'mzansi magic',
      'mzansi',
      'mzansi magik'
    ) THEN 'Mzansi Magic'
    
    -- ICC Cricket World Cup variations
    WHEN LOWER(TRIM(Channel2)) IN (
      'icc cricket world cup',
      'icc world cup',
      'icc cricket wc'
    ) THEN 'ICC Cricket World Cup'
    
    -- All other channels: apply proper capitalization
    ELSE INITCAP(TRIM(Channel2))
  END AS channel_name,
  
  -- ==============================================================================
  -- UTC TO SAST TIMESTAMP CONVERSION
  -- Converts UTC timestamp (RecordDate2) to South African Standard Time (UTC+2)
  -- Handles NULL values and invalid date formats
  -- ==============================================================================
  COALESCE(
    TO_TIMESTAMP(TRIM(RecordDate2), 'yyyy-MM-dd HH:mm:ss') + INTERVAL 2 HOURS,
    TO_TIMESTAMP('1900-01-01 00:00:00')  -- Default for invalid dates
  ) AS record_timestamp_sast,
  
  -- ==============================================================================
  -- DATE EXTRACTION (SAST)
  -- Extracts only the date portion in SAST timezone
  -- Converts NULL to 'Unknown'
  -- ==============================================================================
  COALESCE(
    DATE_FORMAT(
      TO_TIMESTAMP(TRIM(RecordDate2), 'yyyy-MM-dd HH:mm:ss') + INTERVAL 2 HOURS,
      'yyyy-MM-dd'
    ),
    'Unknown'
  ) AS record_date_sast,
  
  -- ==============================================================================
  -- TIME EXTRACTION (SAST)
  -- Extracts only the time portion in SAST timezone
  -- Converts NULL to 'Unknown'
  -- ==============================================================================
  COALESCE(
    DATE_FORMAT(
      TO_TIMESTAMP(TRIM(RecordDate2), 'yyyy-MM-dd HH:mm:ss') + INTERVAL 2 HOURS,
      'HH:mm:ss'
    ),
    'Unknown'
  ) AS record_time_sast,
  
  -- ==============================================================================
  -- Handles NULL and empty values
  -- ==============================================================================
  CASE 
    WHEN TRIM(COALESCE(record_sast, '')) = '' THEN 'Unknown'
    ELSE TRIM(record_sast)
  END AS record_sast_original,
  
  -- ==============================================================================
  -- DURATION FORMATTING
  -- Converts Duration 2 timestamp to HH:mm:ss format
  -- Handles NULL values
  -- ==============================================================================
  COALESCE(
    DATE_FORMAT(`Duration 2`, 'HH:mm:ss'),
    '00:00:00'
  ) AS duration_hms,
  
  -- ==============================================================================
  -- WATCH DURATION IN SECONDS
  -- Converts duration to total seconds for analytics
  -- Useful for calculating total watch time
  -- ==============================================================================
  COALESCE(
    UNIX_TIMESTAMP(`Duration 2`) - UNIX_TIMESTAMP('1970-01-01 00:00:00'),
    0
  ) AS watch_seconds

FROM `kenzowealth`.`default`.`viewer_11`

-- ==============================================================================
-- DATA QUALITY FILTERS
-- Excludes records that should not be included in analysis:
-- - Invalid/test channels (break in transmission, test events)
-- - Rare/temporary channels (wimbledon, sawsee)
-- - NULL or empty channel names
-- ==============================================================================
WHERE 
  -- Exclude specific invalid channels
  LOWER(TRIM(COALESCE(Channel2, ''))) NOT IN (
    'break in transmission',
    'dstv events 1',
    ''
  )
  -- Ensure channel name is not NULL
  AND TRIM(COALESCE(Channel2, '')) <> ''
  AND Channel2 IS NOT NULL
  
-- ==============================================================================
-- DEDUPLICATION
-- Groups by all key fields to remove duplicate records
-- ==============================================================================
GROUP BY 
  user_id,
  channel_name,
  record_timestamp_sast,
  record_date_sast,
  record_time_sast,
  record_sast_original,
  duration_hms,
  watch_seconds

-- ==============================================================================
-- SORTING
-- Orders results by timestamp and user for easier analysis
-- ==============================================================================
ORDER BY 
  record_timestamp_sast DESC,
  user_id;

